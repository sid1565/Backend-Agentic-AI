{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "**/*.hbs", "outDir": "dist/src" },
      { "include": "i18n/**/*.json", "outDir": "dist/src" },
      { "include": "assets/fonts/**/*.ttf", "outDir": "dist/src" },
      { "include": "assets/images/**/*.{png,jpg,jpeg}", "outDir": "dist/src" }
    ],
    "watchAssets": true
  }
}

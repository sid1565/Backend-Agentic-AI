# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=school_saas

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
RESET_TOKEN_TTL_MINUTES=30

# Root admin seeded on first boot (rotate password after first login)
ROOT_ADMIN_EMAIL=admin@school-saas.local
ROOT_ADMIN_PASSWORD=replace-with-strong-password

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=apikey
MAIL_PASSWORD=replace-me
MAIL_FROM="School SaaS <noreply@example.com>"

# App URLs (used in emails)
APP_LOGIN_URL=https://app.example.com/login
APP_RESET_PASSWORD_URL=https://app.example.com/reset-password
